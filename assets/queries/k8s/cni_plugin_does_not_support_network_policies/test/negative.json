{
  "apiVersion": "v1",
  "kind": "ConfigMap",
  "metadata": {
    "name": "kube-calico-cfg",
    "namespace": "kube-system",
    "labels": {
      "tier": "node",
      "app": "calico"
    }
  },
  "data": {
    "cni-conf.json": "{\"name\":\"k8s-pod-network\",\"plugins\":[{\"type\":\"calico\",\"log_level\":\"info\",\"datastore_type\":\"kubernetes\",\"nodename\":\"127.0.0.1\",\"ipam\":{\"type\":\"host-local\",\"subnet\":\"usePodCidr\"},\"policy\":{\"type\":\"k8s\"},\"kubernetes\":{\"kubeconfig\":\"/etc/cni/net.d/calico-kubeconfig\"}},{\"type\":\"portmap\",\"capabilities\":{\"portMappings\":true}}]}"
  }
}
